# Copy to .env and fill in the HOST_* paths for your machine.
# All other values are set automatically by docker-compose.yml.

# ── Docker volume mounts (HOST paths — absolute paths on your machine) ────────
# NOTE: TDATR code is now baked into the Docker image — no repo path needed.

# Path to the TDATR model checkpoint file (model.pt)
HOST_TDATR_CHECKPOINT=/home/yousif/TDATR/model.pt

# Path to the Surya layout model checkpoint directory
HOST_SURYA_MODEL_DIR=/home/yousif/surya_layout_model

# ── Optional overrides (defaults are set in docker-compose.yml) ──────────────
# TABLE_DETECTION_THRESHOLD=0.0
# TABLE_DETECTION_PADDING=5.0
# TDATR_MAX_LEN=4096
# TDATR_TEMPERATURE=0.5
# MAX_FILE_SIZE_MB=100
