# Copy to .env and fill in the HOST_* paths for your machine.
# All other values are set automatically by docker-compose.yml.

# ── Docker volume mounts (HOST paths — absolute paths on your machine) ────────
# NOTE: TDATR code is now baked into the Docker image — no repo path needed.

# Path to the TDATR model checkpoint file (model.pt)
HOST_TDATR_CHECKPOINT=./E2E_model/model.pt

# Path to the Surya layout model checkpoint directory
HOST_SURYA_LAYOUT_MODEL_DIR=./LT_model

# Path to the Surya recognition (OCR) model checkpoint directory
HOST_SURYA_RECOGNITION_MODEL_DIR=./TR_model

# TATR Structure Recognition model
TATR_MODEL_NAME=microsoft/table-transformer-structure-recognition-v1.1-all
TATR_TSR_CHECKPOINT=./TSR_model/best_epoch_39_map_0.4389.pt

# Local run variables (matching app/config.py fields)
SURYA_LAYOUT_MODEL_DIR=./LT_model
SURYA_RECOGNITION_MODEL_DIR=./TR_model

# ── Optional overrides (defaults are set in docker-compose.yml) ──────────────
# TABLE_DETECTION_THRESHOLD=0.0
# TABLE_DETECTION_PADDING=5.0
# TDATR_MAX_LEN=4096
# TDATR_TEMPERATURE=0.5
# MAX_FILE_SIZE_MB=100
